{
  "permissions": {
    "allow": [
      "Bash(curl -sL -o mahou.zip \"https://gitea.com/BladeMight/Mahou/archive/latest-commit.zip\")",
      "Bash(unzip -q mahou.zip)",
      "Bash(python3 proto_ngram.py \"mahou/Dictionaries-origin/!Russian-big.txt\" \"mahou/Dictionaries-origin/!English-big.txt\")",
      "Bash(python3 -)",
      "Bash(gh auth *)",
      "Bash(git add *)",
      "Bash(git commit -qm 'ci: add GitHub Actions workflow for Windows MSBuild release build *)",
      "Bash(gh repo *)",
      "Bash(gh run *)",
      "Bash(sed -i 's|<TargetFrameworkVersion>v4.0</TargetFrameworkVersion>|<TargetFrameworkVersion>v4.8</TargetFrameworkVersion>|' Mahou/Mahou.csproj)",
      "Bash(sed -i 's|<supportedRuntime version=\"v4.0\" sku=\".NETFramework,Version=v4.0\"/>|<supportedRuntime version=\"v4.0\" sku=\".NETFramework,Version=v4.8\"/>|' Mahou/App.config)",
      "Bash(git commit -qm 'build: retarget to .NET Framework 4.8 *)",
      "Bash(git push *)",
      "Bash(gh api *)",
      "Bash(git commit -qm 'feat: add trigram layout-detection scorer, model generator and CI training *)",
      "Bash(git commit -qm 'docs: add n-gram auto-switch design and tuning notes *)"
    ]
  }
}
